  {
   "cell_type": "code",
   "execution_count": 89,
   "id": "b3db2b44",
   "metadata": {},
   "outputs": [],
   "source": [
    "#bringing in ChargerID and LA data\n",
    "ChargerID     = pd.read_excel(cpid_path / 'CPID_and_local_authority.xlsx')\n",
    "#correcting erroneous entries\n",
    "ChargerID.loc[ChargerID['CPID']==61625, 'local_authority'] = 'Renfrewshire'\n",
    "ChargerID.loc[ChargerID['CPID']=='CMU2211', 'local_authority'] = 'North Lanarkshire'\n"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 90,
   "id": "b14fcc2d",
   "metadata": {},
   "outputs": [],
   "source": [
    "#bringing in charging speed data\n",
    "ChargerSpeeds = pd.read_excel(cpid_path / 'CPID_and_charger_speed.xlsx')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 91,
   "id": "de202270",
   "metadata": {},
   "outputs": [],
   "source": [
    
    "base_path = Path(ur_path\\'Spatio-Temporal-Modelling-of-Electric-Vehicle-Charging-Demand\\datasets\\Sessions_from_ChargePlaceScotland\\infos_cpids')\n",
    "# DEFINE FILENAMES (Soft-coded)\n",
    "# This list maintains the exact order you provided\n",
    "files = [\n",
    "    \"Oct22.xlsx\", \"Nov22.xlsx\", \"Dec22.xlsx\", \n",
    "    \"Jan23.xlsx\", \"Feb23.xlsx\", \"March23.xlsx\",\n",
    "    \"April23.xlsx\", \"May23.xlsx\", \"June23.xlsx\", \n",
    "    \"July23.xlsx\", \"Aug23.xlsx\", \"Sep23.xlsx\",\n",
    "    \"Oct23.xlsx\", \"Nov23.xlsx\", \"Dec23.xlsx\", \n",
    "    \"Jan24.xlsx\", \"Feb24.xlsx\", \"March24.xlsx\", \n",
    "    \"April24.xlsx\", \n",
    "    \"May24.xlsx\", \"June24.xlsx\", \"July24.xlsx\", \n",
    "    \"Aug24.xlsx\", \"Sep24.xlsx\", \"Oct24.xlsx\",\n",
    "    \"Nov24.xlsx\", \"Dec24.xlsx\", \"Jan25.xlsx\", \n",
    "    \"Feb25.xlsx\", \"April25.xlsx\"\n",
    "]\n",
    "\n",
    "# LOADING DATA\n",
    "# We create a list of dataframes by joining base_path with each filename\n",
    "df_list = [pd.read_excel(base_path / f) for f in files]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 93,
   "id": "874efd4a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "df loaded with 4716905 rows.\n"
     ]
    }
   ],
   "source": [
    "# CREATING THE DATAFRAMES\n",
    "# df: The full dataset (all files)\n",
    "df= pd.concat(df_list, ignore_index=True)\n",
    "# 5. FORMATTING DATES\n",
    "# Applying the date formatting to both\n",
    "for frame in [df]:\n",
    "    frame['Start'] = pd.to_datetime(frame['Start'], dayfirst=True, errors='coerce')\n",
    "    frame['Start'] = frame['Start'].dt.strftime('%Y-%m-%d')\n",
    "print(f\"df loaded with {len(df)} rows.\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 108,
   "id": "bbc1bef7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Merge complete. Number of rows: 4716905\n"
     ]
    }
   ],
   "source": [
    "# --- CONVERSION BEFORE MERGE ---\n",
    "#  Convert CPID to string in the sessions DataFrame\n",
    "# We use a lambda to ensure that integers (like 61625) don't get a \".0\" suffix\n",
    "df['CPID'] = df['CPID'].apply(lambda x: str(int(x)) if pd.api.types.is_number(x) and pd.notnull(x) and float(x).is_integer() else str(x))\n",
    "# 2. Convert CPID to string in the reference (ChargerID) DataFrame\n",
    "ChargerID['CPID'] = ChargerID['CPID'].apply(lambda x: str(int(x)) if pd.api.types.is_number(x) and pd.notnull(x) and float(x).is_integer() else str(x))\n",
    "# --- MERGING ---\n",
    "# Now that types match perfectly, we can merge\n",
    "merged_df = pd.merge(df, ChargerID, on='CPID', how='left')\n",
    "print(f\"Merge complete. Number of rows: {len(merged_df)}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 109,
   "id": "5648d7c8",
   "metadata": {},
   "outputs": [],
   "source": [
    "#removing data where energy consumed = 0kWh\n",
    "merged_df = merged_df[merged_df['Consumed(kWh)']>0]\n",
    "#removing sessions where duration is 00:00:00\n",
    "merged_df = merged_df[merged_df['Duration'] != pd.to_datetime('00:00:00').time()]\n",
    "#removing nulls from merged_df\n",
    "merged_df = merged_df.dropna()"
   ]
  },
