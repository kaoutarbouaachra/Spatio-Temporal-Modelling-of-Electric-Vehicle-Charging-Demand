    "# Path for CPID information (the reference files)\n",
    "# SETTINGS - The only place you need to change the path\n",
    "ur_path=path(your_path)",
    "cpid_path = Path(ur_path\\'Spatio-Temporal-Modelling-of-Electric-Vehicle-Charging-Demand\\datasets')",
   ]
